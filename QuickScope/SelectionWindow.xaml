<Window x:Class="QuickScope.SelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:QuickScope"
        mc:Ignorable="d"
        Title="SelectionWindow" Height="450" Width="800"
        WindowStyle="None" WindowState="Maximized"
        Topmost="True" ShowInTaskbar="False"
        Cursor="Cross" Background="Transparent"
        MouseDown="Window_MouseDown" 
        MouseMove="Window_MouseMove" 
        MouseUp="Window_MouseUp"
        KeyDown="Window_KeyDown"
        >
    <Grid>
        <Image x:Name="FrozenScreenImage" Stretch="Fill" />
        
        <Canvas Background="#22000000">
            <Rectangle x:Name="SelectionBox" 
                       Stroke="White" StrokeThickness="2" 
                       Fill="#44FFFFFF"
                       Visibility="Collapsed" />
        </Canvas>
    </Grid>
</Window>
